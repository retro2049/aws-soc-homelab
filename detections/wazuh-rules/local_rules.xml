<group name="soc_lab,">

  <!-- ═══ Kerberoasting: RC4 TGS ticket requested (Event 4769) ═══ -->
  <rule id="100001" level="12">
    <if_sid>60103</if_sid>
    <field name="win.eventdata.ticketEncryptionType">0x17</field>
    <description>Kerberoasting — RC4 TGS requested for $(win.eventdata.serviceName)</description>
    <mitre><id>T1558.003</id></mitre>
  </rule>

  <!-- ═══ AS-REP Roasting: TGT requested without preauth (Event 4768) ═══ -->
  <rule id="100015" level="12">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4768$</field>
    <field name="win.eventdata.preAuthType">^0$</field>
    <description>AS-REP Roasting — TGT requested for $(win.eventdata.targetUserName) without preauth</description>
    <mitre><id>T1558.004</id></mitre>
  </rule>

  <!-- ═══ Pass-the-Hash: NTLM network logon ═══ -->
  <rule id="100002" level="14">
    <if_sid>60103</if_sid>
    <field name="win.eventdata.logonType">^3$</field>
    <field name="win.eventdata.authenticationPackageName">NTLM</field>
    <description>Possible Pass-the-Hash — NTLM network logon by $(win.eventdata.targetUserName)</description>
    <mitre><id>T1550.002</id></mitre>
  </rule>

  <!-- ═══ DCSync: DS-Replication-Get-Changes-All used (Event 4662) ═══ -->
  <rule id="100020" level="15">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4662$</field>
    <field name="win.eventdata.properties" type="pcre2">1131f6aa-9c07-11d1-f79f-00c04fc2dcd2|1131f6ad-9c07-11d1-f79f-00c04fc2dcd2|89e95b76-444d-4c62-991a-0facbeda640c</field>
    <description>DCSync attack — replication rights used by $(win.eventdata.subjectUserName)</description>
    <mitre><id>T1003.006</id></mitre>
  </rule>

  <!-- ═══ Suspicious PowerShell execution ═══ -->
  <rule id="100003" level="10">
    <if_sid>91802</if_sid>
    <regex>IEX|Invoke-Expression|DownloadString|EncodedCommand|-enc |-nop|FromBase64String|New-Object Net.WebClient</regex>
    <description>Suspicious PowerShell on $(agent.name)</description>
    <mitre><id>T1059.001</id></mitre>
  </rule>

  <!-- ═══ LSASS memory access — credential dumping ═══ -->
  <rule id="100004" level="15">
    <if_sid>61612</if_sid>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)lsass\.exe</field>
    <description>LSASS memory access — credential dumping by $(win.eventdata.sourceImage)</description>
    <mitre><id>T1003.001</id></mitre>
  </rule>

  <!-- ═══ Brute force then success ═══ -->
  <rule id="100005" level="12" frequency="5" timeframe="60">
    <if_matched_sid>60122</if_matched_sid>
    <same_field>win.eventdata.targetUserName</same_field>
    <description>Brute force followed by success — $(win.eventdata.targetUserName)</description>
    <mitre><id>T1110</id></mitre>
  </rule>

  <!-- ═══ Password Spraying — many users failing from same source ═══ -->
  <rule id="100016" level="12" frequency="10" timeframe="120">
    <if_matched_sid>60122</if_matched_sid>
    <same_field>win.eventdata.ipAddress</same_field>
    <different_field>win.eventdata.targetUserName</different_field>
    <description>Password Spray — many users failed from $(win.eventdata.ipAddress)</description>
    <mitre><id>T1110.003</id></mitre>
  </rule>

  <!-- ═══ Lateral movement: new service installed (Event 7045) ═══ -->
  <rule id="100006" level="12">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^7045$</field>
    <description>New Windows service installed — possible lateral movement: $(win.eventdata.serviceName)</description>
    <mitre><id>T1021.002</id></mitre>
  </rule>

  <!-- ═══ New local admin account (Events 4720 + 4732) ═══ -->
  <rule id="100007" level="12">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4720$</field>
    <description>New user account created — $(win.eventdata.targetUserName)</description>
    <mitre><id>T1136.001</id></mitre>
  </rule>

  <rule id="100008" level="13">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4732$</field>
    <field name="win.eventdata.targetUserName">Administrators</field>
    <description>User added to local Administrators — $(win.eventdata.memberName)</description>
    <mitre><id>T1078</id></mitre>
  </rule>

  <!-- ═══ Shadow copy deletion (ransomware pre-encryption) ═══ -->
  <rule id="100010" level="15">
    <if_sid>61613</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)vssadmin.*delete.*shadows|wmic.*shadowcopy.*delete</field>
    <description>Shadow copies deleted — possible ransomware on $(agent.name)</description>
    <mitre><id>T1490</id></mitre>
  </rule>

  <!-- ═══ Mass file modification — ransomware encryption ═══ -->
  <rule id="100011" level="15" frequency="20" timeframe="10">
    <if_matched_sid>550</if_matched_sid>
    <same_field>agent.name</same_field>
    <description>Mass file modification — possible ransomware encrypting on $(agent.name)</description>
    <mitre><id>T1486</id></mitre>
  </rule>

  <!-- ═══ Golden Ticket detection — TGT lifetime > 10 hours ═══ -->
  <rule id="100021" level="14">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4769$</field>
    <field name="win.eventdata.targetUserName" type="pcre2">^(?!krbtgt).*$</field>
    <regex type="osregex">TGT lifetime: \d{2}\.\d{2}:\d{2}:\d{2}</regex>
    <description>Possible Golden Ticket — abnormal TGT lifetime detected</description>
    <mitre><id>T1558.001</id></mitre>
  </rule>

  <!-- ═══ NTLM Relay indicator — relay tool patterns ═══ -->
  <rule id="100022" level="13">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4624$</field>
    <field name="win.eventdata.authenticationPackageName">NTLM</field>
    <field name="win.eventdata.workstationName" type="pcre2">^(?!.*\$).{1,4}$</field>
    <description>Suspicious NTLM auth from short workstation name — possible relay attack</description>
    <mitre><id>T1557.001</id></mitre>
  </rule>

  <!-- ═══ GPO modification — possible GPO abuse ═══ -->
  <rule id="100023" level="13">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^5136$|^5137$|^5141$</field>
    <field name="win.eventdata.objectClass">groupPolicyContainer</field>
    <description>Group Policy Object modified by $(win.eventdata.subjectUserName)</description>
    <mitre><id>T1484.001</id></mitre>
  </rule>

</group>
